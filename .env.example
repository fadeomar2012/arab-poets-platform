# Supabase pooled runtime connection (recommended port 6543)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres
# Supabase direct connection for Payload migrations (recommended port 5432)
DATABASE_MIGRATION_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

PAYLOAD_SECRET=replace-with-at-least-32-random-characters
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=arab-poets

# Secret that gates the draft-preview endpoint (/api/preview). Editors reach
# unpublished content only through this. Use a long random value; never commit it.
PREVIEW_SECRET=replace-with-a-long-random-preview-secret

# CMS data behavior
# A configured database that fails at query time NEVER silently downgrades to
# mock content — the real error is surfaced (dev and production alike).
# Set to true to skip Payload entirely and render mock content (pure frontend dev).
CMS_USE_MOCK_CONTENT=false
# Set to true to allow falling back to mock content when a Payload query fails.
# Leave false so query failures surface instead of masquerading as content.
CMS_ALLOW_MOCK_FALLBACK=false

# Development only. Never enable on staging or production after migrations exist.
PAYLOAD_DB_PUSH=false

# Max Postgres pool connections for the runtime (pooled) URL. Default 10.
# Keep within your provider's pooler limits.
DATABASE_POOL_MAX=10

# Email (Payload transactional mail, e.g. password reset).
# When SMTP_HOST + SMTP_USER + SMTP_PASS are all set, real SMTP is used.
# Otherwise a console/stream transport is used (no real mail, no credentials needed).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=no-reply@arabpoets.org
SMTP_FROM_NAME=Arab Poets Association

# Seed behavior
# Keep false for normal repeatable runs. Set true only to intentionally refresh fixture content.
SEED_UPDATE_EXISTING=false
