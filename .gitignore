# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# E2E / Playwright
/test-results/
/playwright-report/
/e2e/results/
/playwright/.cache/

# Release packaging output (generated by scripts/package-release.mjs)
/release/
*.zip
*.sha256
# Keep the committed seed dataset checksum (overrides the *.sha256 rule above).
!/seed-data/facebook-v2/MANIFEST.sha256

# Seed binary assets are NOT tracked in git (they bloat the repo). Only the JSON
# dataset, README, and MANIFEST are versioned. The images/contact-sheets are kept
# on disk so `npm run seed` can upload them; obtain them from the client-provided
# facebook_data_seed_v2 package. See docs/FACEBOOK_SEED.md.
/seed-data/facebook-v2/images/
/seed-data/facebook-v2/catalog/

# Local Claude / editor state
/.claude/
/.vscode/
/.idea/
